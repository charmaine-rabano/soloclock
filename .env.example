# ---------------------------------------------------------------------------
# Soloclock environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# Database (Supabase Postgres) --------------------------------------------------
# Pooled connection used by the app at runtime (PgBouncer, port 6543).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection used by Prisma Migrate / Studio (port 5432).
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Auth.js
# Secret used to sign session tokens. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Canonical URL of the deployment. Optional locally; set in preview/production.
# AUTH_URL="http://localhost:3000"
